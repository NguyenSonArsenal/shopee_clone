## Run command: npm install -g editorconfig if this file is not working

root = true

### All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

### Markdown
[*.md]
trim_trailing_whitespace = false

### YAML
[*.{yml,yaml}]
indent_size = 2

### Frontend files
[*.{css,scss,less,js,json,ts,sass,html,hbs,mustache,phtml,html.twig,blade.php}]
indent_style = space
indent_size = 2
